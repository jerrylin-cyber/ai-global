#!/bin/bash

# AI Global：統一 AI 工具設定管理器
# https://github.com/lazyjerry/ai-global

# 版本號
VERSION="2.1.2"

# GitHub 倉庫路徑
REPO_SLUG="lazyjerry/ai-global"

# 已知的 AI 工具設定模式
# 格式：nodes|key|name|agents_md|rules|commands|skills|subagents|color
declare -a KNOWN_PATTERNS=(
  ".claude|claude|Claude Code|CLAUDE.md|.|commands|skills|agents|\\033[38;5;180m"
  ".clawdbot|clawdbot|Clawdbot Code|AGENTS.md|.|.|skills|subagents|\\033[38;5;208m"
  ".codex|codex|OpenAI Codex|AGENTS.md|rules|.|skills|agents|\\033[38;5;9m"
  ".cursor|cursor|Cursor|AGENTS.md|rules|commands|skills|agents|\\033[38;5;12m"
  ".gemini|antigravity|Antigravity|GEMINI.md|.|.|antigravity/skills|.|\\033[38;5;214m"
  ".gemini|gemini|Gemini CLI|GEMINI.md|.|.|skills|.|\\033[38;5;220m"
  ".kiro|kiro|Kiro CLI|AGENTS.md|steering|.|skills|agents|\\033[38;5;117m"
  ".kilocode|kilocode|Kilo Code|AGENTS.md|rules|commands|skills|.|\\033[38;5;165m"
  ".opencode, .config/opencode|opencode|OpenCode|AGENTS.md|.|commands|skills|agents|\\033[38;5;225m"
  ".windsurf, .codeium/windsurf|windsurf|Windsurf|AGENTS.md|rules|.|skills|.|\\033[38;5;159m"
)

# 顏色
BLUE='\033[0;34m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
RED='\033[0;31m'
GRAY='\033[0;90m'
NC='\033[0m'

log_info() { echo -e "${BLUE}[INFO]${NC} $1"; }
log_ok() { echo -e "${GREEN}[OK]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }

# 美化目錄路徑顯示
beautify_dir() {
  local path="$1"
  if [[ "$path" == "$HOME"* ]]; then
    echo "~${path#$HOME}"
  else
    echo "$path"
  fi
}

# 顯示執行環境資訊
log_context_info() {
  local base_dir="$1"
  log_info "目錄: $(beautify_dir "$base_dir")"
  echo ""
}

# 解析工具模式字串
parse_pattern() {
  IFS='|' read -r nodes key name agents_md rules commands skills subagents color <<< "$1"
  IFS=', ' read -ra node_array <<< "$nodes"
}

# 更新：掃描、合併、更新 symlink
update_links() {
  local base_dir="$HOME"
  log_context_info "$base_dir" || return

  log_info "正在掃描 AI 工具..."

  local agents_md_dir="$base_dir/.ai-global/AGENTS.md"
  local rules_dir="$base_dir/.ai-global/rules"
  local commands_dir="$base_dir/.ai-global/commands"
  local skills_dir="$base_dir/.ai-global/skills"
  local subagents_dir="$base_dir/.ai-global/agents"
  local backups_dir="$base_dir/.ai-global/backups"

  local total_tools=0

  # 若 .ai-global 目錄不存在則建立
  if [[ ! -d "$base_dir/.ai-global" ]]; then
    mkdir -p "$base_dir/.ai-global"
  fi

  # 處理 AGENTS.md
  local is_new_agents_md=false
  if [[ ! -L "$agents_md_dir" ]] && [[ ! -f "$agents_md_dir" ]]; then
    touch "$agents_md_dir"
    is_new_agents_md=true
  fi

  # 建立目錄
  mkdir -p "$rules_dir" "$commands_dir" "$skills_dir" "$subagents_dir" "$backups_dir"

  for pattern in "${KNOWN_PATTERNS[@]}"; do
    parse_pattern "$pattern"

    for tool_node in "${node_array[@]}"; do
      local tool_dir="$base_dir/$tool_node"

      if [[ -d "$tool_dir" ]]; then
        total_tools=$((total_tools + 1))

        echo ""
        echo -e "${GREEN}[OK]${NC} ${color}找到: $name${NC}"

        local _type_keys=("file" "dir" "dir" "dir" "dir")
        local _type_nodes=("$agents_md" "$rules" "$commands" "$skills" "$subagents")
        local _type_targets=("$agents_md_dir" "$rules_dir" "$commands_dir" "$skills_dir" "$subagents_dir")

        for _ti in "${!_type_keys[@]}"; do
          local type_key="${_type_keys[$_ti]}"
          local type_node="${_type_nodes[$_ti]}"
          local target_dir="${_type_targets[$_ti]}"

          if [[ "$type_node" != "." ]]; then
            local type_dir="$tool_dir/$type_node"

            # 若非 symlink，則建立 symlink
            if [[ ! -L "$type_dir" ]]; then
              # 若目錄已存在，備份、複製、移除
              if [[ -e "$type_dir" ]]; then
                # 備份
                local backup_file="$backups_dir/${tool_node//\//_}.${type_node//\//_}.backup"
                cp -r -- "$type_dir" "$backup_file" 2> /dev/null

                if [[ "$type_key" == "file" ]]; then
                  # 複製
                  if [[ "$is_new_agents_md" == true ]]; then
                    mkdir -p "$(dirname "$target_dir")" 2> /dev/null
                    echo "<!-- $name -->" >> "$target_dir"
                    cat -- "$type_dir" >> "$target_dir"
                    echo "" >> "$target_dir"
                    echo "" >> "$target_dir"
                  fi
                else
                  # 若共用目錄已有其他工具的檔案，發出警告
                  local existing_count
                  existing_count=$(find "$target_dir" -type f 2>/dev/null | wc -l | tr -d ' ')
                  if [[ "$existing_count" -gt 0 ]]; then
                    log_warn "共用目錄 $(beautify_dir "$target_dir") 已有 $existing_count 個檔案"
                    log_warn "來自 ${color}$name${NC}${YELLOW} 的檔案將合併至共用目錄${NC}"
                  fi

                  # 複製所有檔案（若存在則覆蓋）
                  find "$type_dir" -type f -print0 2> /dev/null | while IFS= read -r -d '' file_dir; do
                    local target_file="$target_dir/${file_dir#$type_dir/}"
                    mkdir -p "$(dirname "$target_file")" 2> /dev/null
                    cp -- "$file_dir" "$target_file" 2> /dev/null || true
                  done
                fi

                # 移除
                rm -rf -- "$type_dir"
              fi

              # 無論是否存在都建立 symlink
              ln -s -- "$target_dir" "$type_dir"
            fi

            # 顯示 symlink
            local src_dir=$(beautify_dir "$type_dir")
            local tgt_dir=$(beautify_dir "$target_dir")
            local src_spaces=$((40 - ${#src_dir}))
            src_spaces=$((src_spaces > 0 ? src_spaces : 1))
            local src_spacing="                                        "
            src_spacing="${src_spacing:0:$src_spaces}"
            echo -e "${color}${src_dir}${src_spacing} ${GRAY}→ ${tgt_dir}${NC}"
          fi
        done
      fi
    done
  done

  echo ""

  # 檢查是否找到任何工具
  if [[ $total_tools -eq 0 ]]; then
    log_info "未找到任何 AI 工具設定"
    log_info "未偵測到 AI 工具設定目錄 (如 ~/.cursor/ 或 ~/.claude/)"
    # 移除空的 .ai-global 目錄
    rm -rf -- "$base_dir/.ai-global" 2> /dev/null
    echo ""
    return
  fi

  if [[ "$is_new_agents_md" == true ]]; then
    if [[ -f "$agents_md_dir" ]] && ! grep -q '[^[:space:]]' "$agents_md_dir" 2> /dev/null; then
      cat > "$agents_md_dir" << 'EOF'
# AI 程式助手

<!-- 在此加入您的提示詞，將同步至所有 AI 工具。 -->
EOF
    fi
    log_info "已合併 AGENTS.md: $(beautify_dir "$agents_md_dir")"
  else
    log_info "跳過合併: $(beautify_dir "$agents_md_dir") (已存在)"
  fi

  log_ok "完成！"
  echo ""
}

# 顯示 symlink 狀態
show_status() {
  local base_dir="$HOME"
  log_context_info "$base_dir" || return

  local total_links=0

  local _so_agents_md="" _so_rules="" _so_commands="" _so_skills="" _so_subagents=""

  for pattern in "${KNOWN_PATTERNS[@]}"; do
    parse_pattern "$pattern"

    for tool_node in "${node_array[@]}"; do
      local tool_dir="$base_dir/$tool_node"

      if [[ -d "$tool_dir" ]]; then
        local _stype_nodes=("$agents_md" "$rules" "$commands" "$skills" "$subagents")
        local _stype_keys=("agents_md" "rules" "commands" "skills" "subagents")

        for _si in "${!_stype_nodes[@]}"; do
          local type_node="${_stype_nodes[$_si]}"
          local output_key="${_stype_keys[$_si]}"

          if [[ "$type_node" != "." ]]; then
            local type_dir="$tool_dir/$type_node"
            if [[ -L "$type_dir" ]]; then
              local target_dir
              target_dir=$(readlink "$type_dir" 2> /dev/null || true)
              if [[ "$target_dir" == *".ai-global"* ]]; then
                local beautified
                beautified=$(beautify_dir "$type_dir")
                local _line="  ${color}${beautified}${NC}\n"
                case "$output_key" in
                  agents_md) _so_agents_md+="$_line" ;;
                  rules) _so_rules+="$_line" ;;
                  commands) _so_commands+="$_line" ;;
                  skills) _so_skills+="$_line" ;;
                  subagents) _so_subagents+="$_line" ;;
                esac
                total_links=$((total_links + 1))
              fi
            fi
          fi
        done
      fi
    done
  done

  if [[ $total_links -eq 0 ]]; then
    echo "  未找到任何 symlink"
    echo ""
    return
  fi

  local _titles=("AGENTS.md" "rules" "commands" "skills" "agents")
  local _contents=("$_so_agents_md" "$_so_rules" "$_so_commands" "$_so_skills" "$_so_subagents")

  for _si in "${!_titles[@]}"; do
    local content="${_contents[$_si]}"
    if [[ -n "$content" ]]; then
      echo -e "${BLUE}[${_titles[$_si]}]${NC}"
      echo -e -n "$content\n"
    fi
  done
}

# 列出支援的工具
list_tools() {
  local base_dir="$HOME"
  log_context_info "$base_dir" || return

  echo -e "  ${BLUE}工具             Key          目錄                          AGENTS.md Rules Commands Skills Agents 狀態${NC}"
  echo -e "  ${BLUE}-----------------------------------------------------------------------------------------------------------${NC}"

  for pattern in "${KNOWN_PATTERNS[@]}"; do
    parse_pattern "$pattern"

    local row_color="${GRAY}"
    local status="未找到"

    for tool_node in "${node_array[@]}"; do
      local tool_dir="$base_dir/$tool_node"

      if [[ -d "$tool_dir" ]]; then
        row_color="$color"
        status="已安裝"
        break
      fi
    done

    echo -e "  ${row_color}$(printf '%-17s %-13s %-31s' "$name" "$key" "$nodes") $([[ "$agents_md" == "." ]] && echo "." || echo "○")        $([[ "$rules" == "." ]] && echo "." || echo "○")      $([[ "$commands" == "." ]] && echo "." || echo "○")       $([[ "$skills" == "." ]] && echo "." || echo "○")      $([[ "$subagents" == "." ]] && echo "." || echo "○")    ${status}${NC}"
  done
  echo ""
}

# 列出可用備份
list_backups() {
  local base_dir="$HOME"
  log_context_info "$base_dir" || return

  local backups_dir="$base_dir/.ai-global/backups"
  local backups_list=$(find "$backups_dir" -maxdepth 1 -name "*.backup" 2> /dev/null | sort)

  if [[ -z "$backups_list" ]]; then
    echo "  未找到任何備份"
    echo ""
    return
  fi

  echo -e "  ${BLUE}備份檔案${NC}"
  echo "  ----------------------------------------------------------------------"

  while IFS= read -r backup_dir; do
    [[ -z "$backup_dir" ]] && continue
    local display_dir=$(beautify_dir "$backup_dir")
    echo -e "  ${display_dir}"
  done <<< "$backups_list"
  echo ""
}

# 取消連結單一工具
unlink_one_tool() {
  local base_dir="$1"
  local tool_node="$2"
  local agents_md="$3"
  local rules="$4"
  local commands="$5"
  local skills="$6"
  local subagents="$7"
  local color="$8"

  local unlinked_count=0

  for type_node in "$agents_md" "$rules" "$commands" "$skills" "$subagents"; do
    if [[ "$type_node" != "." ]]; then
      local type_dir="$base_dir/$tool_node/$type_node"
      if [[ -L "$type_dir" ]]; then
        rm -- "$type_dir"
        log_ok "已取消連結: ${color}$(beautify_dir "$type_dir")${NC}"
        ((unlinked_count++))

        # 從備份還原
        local backup_file="$base_dir/.ai-global/backups/${tool_node//\//_}.${type_node//\//_}.backup"
        if [[ -e "$backup_file" ]]; then
          cp -r -- "$backup_file" "$type_dir" 2> /dev/null
        fi
      fi
    fi
  done

  # 刪除工具備份
  local backups_dir="$base_dir/.ai-global/backups"
  [[ -d "$backups_dir" ]] && for backup_dir in "$backups_dir"/${tool_node//\//_}.*.backup; do
    [[ -e "$backup_dir" ]] && rm -rf -- "$backup_dir"
  done

  _UNLINK_COUNT=$unlinked_count
}

# 取消連結所有工具
unlink_all_tools() {
  local base_dir="$1"
  log_context_info "$base_dir" || return

  local total_unlinked=0

  for pattern in "${KNOWN_PATTERNS[@]}"; do
    parse_pattern "$pattern"

    for tool_node in "${node_array[@]}"; do
      local tool_dir="$base_dir/$tool_node"

      if [[ -d "$tool_dir" ]]; then
        unlink_one_tool "$base_dir" "$tool_node" "$agents_md" "$rules" "$commands" "$skills" "$subagents" "$color"
        total_unlinked=$((total_unlinked + _UNLINK_COUNT))
      fi
    done
  done

  if [[ $total_unlinked -gt 0 ]]; then
    log_ok "已取消連結全部 $total_unlinked 個 symlink"
  else
    echo "  未找到任何 symlink"
  fi
}

# 取消連結指令
unlink_tool() {
  local query_key="$1"

  if [[ -z "$query_key" ]]; then
    log_error "用法: ai-global unlink <key> 或 ai-global unlink all"
    echo ""
    return 1
  fi

  local base_dir="$HOME"

  if [[ "$query_key" == "all" ]]; then
    unlink_all_tools "$base_dir"
    echo ""
    return 0
  fi

  # 從 KNOWN_PATTERNS 中搜尋匹配的模式
  local match=""
  for pattern in "${KNOWN_PATTERNS[@]}"; do
    parse_pattern "$pattern"
    if [[ "$key" == "$query_key" ]]; then
      match="$pattern"
      break
    fi
  done

  if [[ -z "$match" ]]; then
    log_error "未知的工具: $query_key"
    echo "請使用正確的 <key>"
    echo ""
    list_tools
    return 1
  fi

  log_context_info "$base_dir" || return

  local has_found=false

  # 解析模式並取消連結工具
  parse_pattern "$match"

  for tool_node in "${node_array[@]}"; do
    local tool_dir="$base_dir/$tool_node"

    if [[ -d "$tool_dir" ]]; then
      has_found=true
      unlink_one_tool "$base_dir" "$tool_node" "$agents_md" "$rules" "$commands" "$skills" "$subagents" "$color"
      local unlinked_count=$_UNLINK_COUNT
      if [[ $unlinked_count -gt 0 ]]; then
        log_ok "已從 ${color}$(beautify_dir "$tool_dir")${NC} 取消連結 $unlinked_count 個 symlink"
      else
        log_info "${color}$(beautify_dir "$tool_dir")${NC} 未找到 symlink"
      fi
      echo ""
    fi
  done

  if [[ "$has_found" != true ]]; then
    log_warn "未找到工具 '$query_key'"
    echo ""
  fi
}

# 解析 GitHub 參照，取得 owner、repo 及可選路徑
parse_github_ref() {
  local input="$1"

  # 移除 https://github.com/ 或 github.com/ 前綴
  input="${input#https://github.com/}"
  input="${input#http://github.com/}"
  input="${input#github.com/}"

  # 移除 /blob/main/ 或 /blob/master/ 或 /tree/main/ 等路徑
  input=$(echo "$input" | sed -E 's|/blob/[^/]+/|/|; s|/tree/[^/]+/|/|')

  echo "$input"
}

# 從 frontmatter 中擷取名稱（name: "..."）
extract_meta_name() {
  local file="$1"
  local default_name="$2"
  if [[ ! -f "$file" ]]; then
    echo "$default_name"
    return
  fi
  # 匹配 name: "value" 或 name: value
  local extracted=$(grep -m 1 "^name:" "$file" | sed -E 's/^name:[[:space:]]*["'\'']?([^"'\'']+)["'\'']?/\1/' | xargs 2> /dev/null || true)
  if [[ -n "$extracted" ]]; then
    echo "$extracted"
  else
    echo "$default_name"
  fi
}

# 從 GitHub 下載資源（泛用）
# $1: GitHub 參照
# $2: 目標目錄
# $3: 中繼資料檔名（如 SKILL.md、RULE.md、COMMAND.md）
# $4: 資源標籤（如 skill、rule、command）
# $5: 搜尋子目錄（複數形 單數形，如 "skills skill"）
download_from_github() {
  local input="$1"
  local target_dir="$2"
  local meta_file="$3"
  local resource_label="$4"
  local search_dirs="$5"

  local parsed
  parsed=$(parse_github_ref "$input")
  local owner
  owner=$(echo "$parsed" | cut -d'/' -f1)
  local repo
  repo=$(echo "$parsed" | cut -d'/' -f2)
  local path
  path=$(echo "$parsed" | cut -d'/' -f3-)

  if [[ -z "$owner" ]] || [[ -z "$repo" ]]; then
    log_error "無效的 GitHub 參照: $input"
    return 1
  fi

  if [[ -n "$path" ]]; then
    log_error "不支援子路徑，僅接受 user/repo 格式: $input"
    return 1
  fi

  # 複製整個倉庫
  local tmp_dir
  tmp_dir=$(mktemp -d)
  local clone_url="https://github.com/$owner/$repo.git"

  log_info "正在複製: $clone_url"

  if git clone --depth 1 --single-branch "$clone_url" "$tmp_dir/$repo"; then
    echo ""
    local source_node="$tmp_dir/$repo"

    if [[ -d "$source_node" ]]; then

      # === 探索階段：找出可安裝的資源（不複製）===
      local -a _install_sources=()
      local -a _install_names=()
      local _install_mode="" # meta_root | meta_sub | files

      # 1. 檢查根目錄是否包含中繼資料檔
      if [[ -f "$source_node/$meta_file" ]]; then
        _install_mode="meta_root"
        local name=$(extract_meta_name "$source_node/$meta_file" "$(basename "$source_node")")
        _install_sources+=("$source_node")
        _install_names+=("$name")
      fi

      # 2. 檢查子目錄（含中繼資料的子目錄 → 直接檔案 fallback）
      if [[ ${#_install_sources[@]} -eq 0 ]]; then
        for dir in $search_dirs; do
          if [[ -d "$source_node/$dir" ]]; then
            # 2a. 搜尋包含中繼資料檔的子目錄
            for d in "$source_node/$dir"/*; do
              [[ ! -d "$d" ]] && continue
              if [[ -f "$d/$meta_file" ]]; then
                _install_mode="meta_sub"
                local name=$(extract_meta_name "$d/$meta_file" "$(basename "$d")")
                _install_sources+=("$d")
                _install_names+=("$name")
              fi
            done

            # 2b. 若無中繼資料子目錄，直接複製目錄內的檔案
            if [[ ${#_install_sources[@]} -eq 0 ]]; then
              for f in "$source_node/$dir"/*; do
                [[ ! -f "$f" ]] && continue
                _install_mode="files"
                _install_sources+=("$f")
                _install_names+=("$(basename "$f")")
              done
            fi
          fi

          if [[ ${#_install_sources[@]} -gt 0 ]]; then
            source_node="$source_node/$dir"
            break
          fi
        done
      fi

      # === 確認階段 ===
      if [[ ${#_install_sources[@]} -gt 0 ]]; then
        log_info "找到以下 $resource_label:"
        for _name in "${_install_names[@]}"; do
          echo "  - $_name"
        done
        echo ""
        log_info "安裝目標: $(beautify_dir "$target_dir")"
        log_warn "請確認您已對此倉庫進行安全掃描"
        read -r -p "是否安裝？[Y/n] " _reply
        _reply="${_reply:-Y}"

        if [[ ! "$_reply" =~ ^[Yy] ]]; then
          log_info "已取消安裝"
          rm -rf -- "$tmp_dir"
          return 0
        fi

        # === 安裝階段 ===
        local resource_count=0

        case "$_install_mode" in
          meta_root)
            local file_dir="$target_dir/${_install_names[0]}"
            mkdir -p -- "$file_dir"
            cp -R -- "${_install_sources[0]}"/* "$file_dir/"
            resource_count=1
            ;;
          meta_sub)
            for _i in "${!_install_sources[@]}"; do
              mkdir -p -- "$target_dir/${_install_names[$_i]}"
              cp -R -- "${_install_sources[$_i]}"/* "$target_dir/${_install_names[$_i]}/"
              echo "  - ${_install_names[$_i]}"
              ((resource_count++))
            done
            ;;
          files)
            for _i in "${!_install_sources[@]}"; do
              cp -- "${_install_sources[$_i]}" "$target_dir/" 2> /dev/null || true
              echo "  - ${_install_names[$_i]}"
              ((resource_count++))
            done
            ;;
        esac

        # === 紀錄安裝來源 ===
        local source_file="$HOME/.ai-global/source.md"
        local github_url="https://github.com/$owner/$repo"
        case "$_install_mode" in
          meta_root)
            echo "${github_url}|${resource_label}|$(beautify_dir "$target_dir/${_install_names[0]}")" >> "$source_file"
            ;;
          meta_sub)
            for _i in "${!_install_names[@]}"; do
              echo "${github_url}|${resource_label}|$(beautify_dir "$target_dir/${_install_names[$_i]}")" >> "$source_file"
            done
            ;;
          files)
            for _i in "${!_install_names[@]}"; do
              echo "${github_url}|${resource_label}|$(beautify_dir "$target_dir/${_install_names[$_i]}")" >> "$source_file"
            done
            ;;
        esac

        echo ""
        log_ok "已從 $owner/$repo 新增 $resource_count 個 $resource_label 至 $(beautify_dir "$target_dir")"
      else
        local searched_dir="${source_node#$tmp_dir/$repo}"
        searched_dir="${searched_dir#/}"
        log_warn "在 $owner/$repo${searched_dir:+/$searched_dir} 中未找到 $resource_label"
      fi
    else
      log_error "找不到路徑: $path"
      rm -rf -- "$tmp_dir"
      return 1
    fi
    rm -rf -- "$tmp_dir"
  else
    rm -rf -- "$tmp_dir"
    log_error "複製失敗: $clone_url"
    return 1
  fi
}

# 檢查輸入是否為 GitHub 參照
not_github_ref() {
  local input="$1"
  # 匹配：user/repo、https://github.com/user/repo、github.com/user/repo
  if [[ "$input" =~ ^https?://github\.com/ ]] \
    || [[ "$input" =~ ^github\.com/ ]] \
    || [[ "$input" =~ ^[a-zA-Z0-9_-]+/[a-zA-Z0-9_.-]+(/.*)?$ ]]; then
    return 1
  fi
  return 0
}

