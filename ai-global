# 升級
upgrade() {
  log_info "正在檢查更新..."

  # 從 GitHub API 取得最新 release tag
  local latest_tag
  latest_tag=$(curl -fsSL "https://api.github.com/repos/$REPO_SLUG/releases/latest" 2> /dev/null | grep '"tag_name"' | sed 's/.*"tag_name": "\(.*\)".*/\1/')

  if [[ -z "$latest_tag" ]]; then
    log_warn "無法取得最新版本"
    return 1
  fi

  local remote_version="${latest_tag#v}"

  if [[ "$remote_version" == "$VERSION" ]]; then
    log_ok "已是最新版本 (v$VERSION)"
    return 0
  fi

  log_info "正在升級: v$VERSION -> v$remote_version"

  local current_script="$0"
  # 若透過 symlink 執行，更新目標檔案
  if [[ -L "$current_script" ]]; then
    current_script=$(readlink "$current_script")
  fi

  local remote_url="https://raw.githubusercontent.com/$REPO_SLUG/$latest_tag/ai-global"
  local exec_temp
  exec_temp=$(mktemp)
  if curl -fsSL "$remote_url" -o "$exec_temp" 2> /dev/null; then
    chmod +x "$exec_temp"

    # 驗證下載的檔案是否為有效腳本
    if ! head -1 "$exec_temp" | grep -q '^#!/bin/bash'; then
      rm -f -- "$exec_temp"
      log_error "下載的檔案不是有效的腳本"
      return 1
    fi

    mv -- "$exec_temp" "$current_script"

    log_ok "已升級至 v$remote_version"
  else
    rm -f -- "$exec_temp"
    log_error "下載更新失敗"
    return 1
  fi
}

# 將所有 ai-global 設定備份至 .agents 目錄
backup_to_agents_dir() {
  local base_dir="$1"
  local config_dir="$base_dir/.ai-global"

  if [[ ! -d "$config_dir" ]]; then
    return 0
  fi

  local config_backup_dir="$base_dir/.agents_ai-global"
  rm -rf -- "$config_backup_dir" 2> /dev/null
  mkdir -p -- "$config_backup_dir"

  # 備份全部
  local types=("AGENTS.md" "skills" "rules" "agents" "commands")

  for type_node in "${types[@]}"; do
    if [[ -e "$config_dir/$type_node" ]]; then
      cp -r -- "$config_dir/$type_node" "$config_backup_dir/" 2> /dev/null
    fi
  done

  # 僅在備份目錄建立成功時記錄結果
  if [[ -d "$config_backup_dir" ]]; then
    log_ok "已將 $(beautify_dir "$config_dir") 備份至 ${GREEN}$(beautify_dir "$config_backup_dir")${NC}"
  fi
}

# 解除安裝
uninstall() {
  log_warn "此操作將完全移除 ai-global 及所有設定"
  read -r -p "確定要解除安裝嗎? [y/N] " _reply
  _reply="${_reply:-N}"

  if [[ ! "$_reply" =~ ^[Yy] ]]; then
    log_info "已取消解除安裝"
    return 0
  fi

  # 將所有設定備份至 .agents 目錄
  echo ""
  backup_to_agents_dir "$HOME"
  unlink_all_tools "$HOME"
  echo ""

  [[ -L /usr/local/bin/ai-global ]] && rm -f -- /usr/local/bin/ai-global
  [[ -L "$HOME/.local/bin/ai-global" ]] && rm -f -- "$HOME/.local/bin/ai-global"

  rm -rf -- "$HOME/.ai-global"
  log_ok "已移除系統設定: $(beautify_dir "$HOME/.ai-global")"

  log_ok "AI Global 已成功解除安裝"
  echo ""
}

