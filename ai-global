# 主程式
main() {
  local cmd="$1"

  # 處理空指令
  if [[ -z "$cmd" ]]; then
    cmd="update"
  fi

  case "$cmd" in
    update) update_links ;;
    status | -s | --status) show_status ;;
    list | -l | --list) list_tools ;;
    backups | -b | --backups) list_backups ;;
    unlink | --unlink) unlink_tool "$2" ;;
    add-skill) add_skill "$2" ;;
    add-rule) add_rule "$2" ;;
    add-command) add_command "$2" ;;

    upgrade | -u | --upgrade) upgrade ;;
    uninstall | --uninstall) uninstall ;;
    version | -v | --version) show_version ;;
    help | --help | -h) show_help ;;
    *)
      log_error "未知的指令: $cmd"
      show_help
      exit 1
      ;;
  esac
}

main "$@"
